rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Blog images can be read by anyone
    match /blog-images/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
